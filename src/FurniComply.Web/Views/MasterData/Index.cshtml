@{
    ViewData["Title"] = "Master Data";
}

<section class="hero">
    <div>
        <p class="eyebrow">Foundation</p>
        <h1>Master Data</h1>
        <p class="lede">Reference catalogs that standardize compliance, procurement, and supplier operations.</p>
    </div>
    <div class="hero-actions">
        <a class="btn btn-outline-secondary btn-back-dashboard" href="/Dashboard/Index"><i class="fa-solid fa-arrow-left"></i> Back to Dashboard</a>
    </div>
</section>

<section class="module-grid">
    <a class="module-card" href="/Suppliers/Index" style="text-decoration:none;color:inherit;">
        <div class="module-card-icon"><i class="fa-solid fa-industry"></i></div>
        <h3>Supplier Directory</h3>
        <p>Approved vendors, categories, certifications, and compliance ratings.</p>
        <span class="button ghost">View Suppliers <i class="fa-solid fa-arrow-right" style="font-size:0.8em;margin-left:0.3rem;"></i></span>
    </a>
    <a class="module-card" href="/Policies/Index" style="text-decoration:none;color:inherit;">
        <div class="module-card-icon"><i class="fa-solid fa-file-lines"></i></div>
        <h3>Policy Catalog</h3>
        <p>Versioned policies, ownership, and effective dates for audit readiness.</p>
        <span class="button ghost">View Policies <i class="fa-solid fa-arrow-right" style="font-size:0.8em;margin-left:0.3rem;"></i></span>
    </a>
    <a class="module-card" href="/ComplianceChecks/Index" style="text-decoration:none;color:inherit;">
        <div class="module-card-icon"><i class="fa-solid fa-clipboard-check"></i></div>
        <h3>Compliance Matrix</h3>
        <p>Status lookups, risk levels, and check classifications.</p>
        <span class="button ghost">View Checks <i class="fa-solid fa-arrow-right" style="font-size:0.8em;margin-left:0.3rem;"></i></span>
    </a>
    <a class="module-card" href="/Suppliers/Documents" style="text-decoration:none;color:inherit;">
        <div class="module-card-icon"><i class="fa-solid fa-folder-open"></i></div>
        <h3>Supplier Documents</h3>
        <p>Compliance document types, expiry controls, and verification outcomes.</p>
        <span class="button ghost">View Documents <i class="fa-solid fa-arrow-right" style="font-size:0.8em;margin-left:0.3rem;"></i></span>
    </a>
</section>

