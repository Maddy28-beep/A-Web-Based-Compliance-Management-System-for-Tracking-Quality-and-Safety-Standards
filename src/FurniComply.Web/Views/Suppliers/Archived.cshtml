@model IEnumerable<FurniComply.Domain.Entities.Supplier>

@{
    ViewData["Title"] = "Archived Suppliers";
    var canManageSuppliers =
        User.IsInRole(FurniComply.Infrastructure.Identity.RoleNames.Procurement) &&
        !User.IsInRole(FurniComply.Infrastructure.Identity.RoleNames.SuperAdmin);
}

<header class="page-header">
    <div>
        <p class="eyebrow">Procurement</p>
        <h1>Archived Suppliers</h1>
        <p class="lede">Soft-deleted supplier profiles retained for audit and potential restoration.</p>
        <div class="page-meta" aria-label="Page context">
            <span class="meta-pill"><i class="fa-solid fa-box-archive"></i> @Model.Count() archived</span>
        </div>
    </div>
    <div class="page-header-actions">
        <a class="btn btn-outline-secondary" asp-action="Index"><i class="fa-solid fa-arrow-left"></i> Back to Active</a>
    </div>
</header>

@if (!Model.Any())
{
    <section class="empty-state" aria-label="No archived suppliers">
        <div class="empty-state-icon"><i class="fa-solid fa-box-archive"></i></div>
        <div>
            <h3>No archived suppliers</h3>
            <p>Archived suppliers will appear here for audit history and restoration.</p>
            <div class="empty-state-actions">
                <a class="btn btn-outline-secondary" asp-action="Index"><i class="fa-solid fa-arrow-left"></i> Back to Active</a>
            </div>
        </div>
    </section>
}
else
{
    <div class="table-card">
        <div class="table-card-header">
            <div>
                <h3 class="table-card-title">Archived Suppliers</h3>
                <p class="table-card-subtitle">Restore is available for authorized roles.</p>
            </div>
        </div>
        <table class="table data-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Category</th>
                <th class="table-cell-center">Status</th>
                <th class="table-cell-center">Approval</th>
                <th class="table-cell-center">Deleted At</th>
                <th class="table-cell-center">Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td class="table-primary-text">@item.Name</td>
                <td class="table-secondary-text">@item.SupplierCategory?.Name</td>
                <td class="table-cell-center table-secondary-text">@item.Status</td>
                <td class="table-cell-center table-secondary-text">@item.ApprovalStatus</td>
                <td class="table-cell-center table-secondary-text">@(item.DeletedAtUtc.HasValue ? item.DeletedAtUtc.Value.ToString("yyyy-MM-dd") : "-")</td>
                <td class="table-cell-center">
                    @if (canManageSuppliers)
                    {
                        <form asp-action="Restore" method="post" class="d-inline" data-confirm="restore">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-primary">Restore</button>
                        </form>
                    }
                    else
                    {
                        <span class="text-muted">-</span>
                    }
                </td>
            </tr>
        }
        </tbody>
        </table>
    </div>
}

@section Scripts {
    <script>
        $(function () {
            $('.data-table').DataTable({
                order: [[4, 'desc']]
            });
        });
    </script>
}
