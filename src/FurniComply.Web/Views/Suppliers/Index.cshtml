@model IEnumerable<FurniComply.Domain.Entities.Supplier>

@{
    ViewData["Title"] = "Suppliers";
    var canManageSuppliers = User.IsInRole(FurniComply.Infrastructure.Identity.RoleNames.Procurement);
    var canShowRowActions = canManageSuppliers;
}

<header class="hero module-header">
    <div>
        <p class="eyebrow">Procurement</p>
        <h1>Suppliers</h1>
        <p class="lede">Manage supplier profiles, certifications, and compliance standing.</p>
        <div class="page-meta" aria-label="Page context">
            <span class="meta-pill"><i class="fa-solid fa-table-list"></i> @Model.Count() total</span>
            <span class="meta-pill"><i class="fa-solid fa-clock"></i> Renewal due dates shown in local time</span>
        </div>
    </div>
    <div class="hero-actions module-header-actions">
        @if (canManageSuppliers)
        {
            <a class="btn btn-success btn-lg px-4" asp-action="Create"><i class="fa-solid fa-plus"></i> Add Supplier</a>
            <a class="btn btn-outline-secondary" asp-action="Archived"><i class="fa-solid fa-box-archive"></i> Archived</a>
        }
    </div>
</header>

@if (!Model.Any())
{
    <section class="empty-state" aria-label="No suppliers">
        <div class="empty-state-icon"><i class="fa-solid fa-industry"></i></div>
        <div>
            <h3>No suppliers found</h3>
            <p>Add a supplier to track approval, renewal, and compliance documentation.</p>
            <div class="empty-state-actions">
                @if (canManageSuppliers)
                {
                    <a class="btn btn-success" asp-action="Create"><i class="fa-solid fa-plus"></i> Add Supplier</a>
                    <a class="btn btn-outline-secondary" asp-action="Archived"><i class="fa-solid fa-box-archive"></i> View Archived</a>
                }
            </div>
        </div>
    </section>
}
else
{
    <div class="table-card suppliers-table-card">
        <div class="table-card-header">
            <div>
                <h3 class="table-card-title">Supplier Directory</h3>
                <p class="table-card-subtitle">Click a row to open details. Pending approvals are subtly marked for faster scanning.</p>
            </div>
        </div>
        <table class="table data-table suppliers-table">
        <thead>
            <tr>
                <th class="sort-hidden-col">CreatedSort</th>
                <th class="col-supplier-name">Name</th>
                <th class="col-supplier-category">Category</th>
                <th class="table-cell-center col-supplier-status">Status</th>
                <th class="table-cell-center col-supplier-approval">Approval</th>
                @if (canShowRowActions)
                {
                    <th class="table-cell-right col-supplier-actions">Actions</th>
                }
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            var rowClass = item.ApprovalStatus == FurniComply.Domain.Enums.SupplierApprovalStatus.Pending
                ? "pending-approval-row"
                : string.Empty;
            <tr data-href="@Url.Action("Details", new { id = item.Id })" class="@rowClass">
                <td class="sort-hidden-col">@item.CreatedAtUtc.Ticks</td>
                <td class="table-primary-text text-truncate-200 col-supplier-name">@item.Name</td>
                <td class="table-secondary-text col-supplier-category">@item.SupplierCategory?.Name</td>
                <td class="table-cell-center col-status col-supplier-status">
                    @if (item.Status == FurniComply.Domain.Enums.SupplierStatus.Active)
                    {
                        <span class="badge bg-success">ACTIVE</span>
                    }
                    else if (item.Status == FurniComply.Domain.Enums.SupplierStatus.OnHold)
                    {
                        <span class="badge bg-warning text-dark">ON HOLD</span>
                    }
                    else if (item.Status == FurniComply.Domain.Enums.SupplierStatus.Suspended)
                    {
                        <span class="badge bg-danger">SUSPENDED</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">@item.Status.ToString().ToUpper()</span>
                    }
                    @if (item.OverrideRequestActive)
                    {
                        <div class="mt-1">
                            <span class="badge bg-info text-dark" title="Override Requested by @item.RequestedBy"><i class="fa-solid fa-paper-plane"></i> REQ</span>
                        </div>
                    }
                    @if (item.IsOverrideActive)
                    {
                        <div class="mt-1">
                            <span class="badge bg-warning text-dark" title="Super Admin Override Active"><i class="fa-solid fa-shield-halved"></i> OVR</span>
                        </div>
                    }
                </td>
                <td class="table-cell-center table-secondary-text col-approval col-supplier-approval">
                    <span class="approval-pill approval-@item.ApprovalStatus.ToString().ToLowerInvariant()">@item.ApprovalStatus</span>
                </td>
                @if (canShowRowActions)
                {
                    <td class="actions-cell suppliers-actions col-actions col-supplier-actions">
                        <a class="icon-action text-warning" asp-action="Edit" asp-route-id="@item.Id"><i class="fa-solid fa-pen"></i></a>
                        <form asp-action="Delete" method="post" class="d-inline" data-confirm="delete">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="icon-action text-danger" aria-label="Archive supplier">
                                <i class="fa-solid fa-box-archive"></i>
                            </button>
                        </form>
                    </td>
                }
            </tr>
        }
        </tbody>
        </table>
    </div>
}

@section Scripts {
    <script>
        $(function () {
            var hasActions = @(canShowRowActions ? "true" : "false");
            var colDefs = [
                { targets: 0, visible: false, searchable: false, className: "sort-hidden-col" },
                { targets: 1, width: "35%" },
                { targets: 2, width: "20%" },
                { targets: 3, width: "15%" },
                { targets: 4, width: "15%" }
            ];
            if (hasActions) {
                colDefs.push({ targets: 5, orderable: false, searchable: false, width: "15%" });
            }

            $('.suppliers-table').DataTable({
                autoWidth: false,
                order: [[0, 'desc']],
                columnDefs: colDefs
            });
        });
    </script>
}
