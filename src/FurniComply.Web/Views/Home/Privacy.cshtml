@{
    ViewData["Title"] = "Privacy & Security";
}

<section class="hero">
    <div>
        <p class="eyebrow">FurniComply</p>
        <h1>Privacy & Security</h1>
        <p class="lede">A prototype summary of how data is handled in the compliance system.</p>
    </div>
    <div class="hero-actions">
        <a class="btn btn-outline-secondary btn-back-dashboard" asp-controller="Dashboard" asp-action="Index"><i class="fa-solid fa-arrow-left"></i> Back to Dashboard</a>
    </div>
</section>

<section class="module-grid privacy-grid">
    <div class="module-card">
        <div class="module-card-icon"><i class="fa-solid fa-shield-halved"></i></div>
        <h3>Access Control</h3>
        <p>Role-based permissions restrict policy management, compliance checks, and procurement actions.</p>
    </div>
    <div class="module-card">
        <div class="module-card-icon"><i class="fa-solid fa-clock-rotate-left"></i></div>
        <h3>Audit Trails</h3>
        <p>Every critical action is logged to support compliance reviews and regulator audits.</p>
    </div>
    <div class="module-card">
        <div class="module-card-icon"><i class="fa-solid fa-database"></i></div>
        <h3>Data Retention</h3>
        <p>Policy, report, and supplier data is retained per regulatory requirements and company policy.</p>
    </div>
    <div class="module-card">
        <div class="module-card-icon"><i class="fa-solid fa-lock"></i></div>
        <h3>Secure Transport</h3>
        <p>Production environments should enforce HTTPS to protect user sessions and data in transit.</p>
    </div>
</section>
