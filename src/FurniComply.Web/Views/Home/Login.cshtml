@model FurniComply.Web.Models.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In - FurniComply</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Fraunces:opsz,wght@9..144,700&display=swap" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <style>
        :root {
            --ink: #1a2333;
            --muted: #4f5b71;
            --surface: #f2f4f8;
            --panel: #ffffff;
            --soft: #f8f1d4;
            --line: #d5ddeb;
            --accent: #f0c73f;
            --accent-ink: #1b2a44;
            --radius-lg: 28px;
            --radius-md: 14px;
            --shadow: 0 30px 56px rgba(19, 25, 39, 0.2);
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: "Manrope", sans-serif;
            background:
                radial-gradient(980px 620px at 8% 8%, rgba(255, 240, 185, 0.26) 0%, transparent 56%),
                radial-gradient(900px 540px at 100% 0%, rgba(79, 126, 201, 0.22) 0%, transparent 54%),
                linear-gradient(145deg, #9aa7bb 0%, #b6c0cf 48%, #c4ccd8 100%);
            color: var(--ink);
            min-height: 100vh;
            display: grid;
            place-items: center;
            padding: 12px;
        }

        .auth-shell {
            width: min(1060px, 100%);
            height: min(86vh, 760px);
            background: var(--panel);
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow);
            overflow: hidden;
            display: grid;
            grid-template-columns: 0.95fr 1.05fr;
            border: 1px solid rgba(255, 255, 255, 0.34);
        }

        .auth-form-pane {
            background:
                radial-gradient(640px 360px at -20% -20%, rgba(255, 255, 255, 0.66) 0%, transparent 68%),
                linear-gradient(180deg, #fff9e5 0%, #f4e8c2 100%);
            padding: 32px 34px 24px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .auth-form-card {
            background: rgba(255, 255, 255, 0.7);
            border: 1px solid rgba(60, 76, 105, 0.14);
            border-radius: 24px;
            box-shadow: 0 14px 34px rgba(47, 59, 84, 0.14);
            backdrop-filter: blur(3px);
            padding: 24px 24px 18px;
            max-width: 560px;
            width: 100%;
            margin: 0 auto;
        }

        .brand-badge {
            align-self: flex-start;
            border: 1px solid rgba(24, 31, 46, 0.2);
            border-radius: 999px;
            font-size: 13px;
            font-weight: 600;
            padding: 8px 16px;
            color: #32415d;
            margin-bottom: 14px;
            background: rgba(255, 255, 255, 0.74);
        }

        .form-title {
            font-family: "Fraunces", serif;
            font-size: clamp(2.35rem, 1.6vw + 1.6rem, 2.9rem);
            line-height: 1.1;
            letter-spacing: -0.02em;
            margin: 0 0 6px;
        }

        .form-subtitle {
            color: var(--muted);
            margin: 0 0 18px;
            font-size: 1.12rem;
            font-weight: 500;
        }

        .field {
            margin-bottom: 12px;
        }

        .field-label {
            display: block;
            margin: 0 0 7px;
            font-size: 0.98rem;
            font-weight: 700;
            color: #3f4d67;
        }

        .field input {
            width: 100%;
            border: 1px solid var(--line);
            border-radius: 999px;
            padding: 13px 16px 13px 44px;
            font-size: 1.08rem;
            background: rgba(255, 255, 255, 0.92);
            color: #1a2333;
        }

        .field input::placeholder {
            color: #74829b;
        }

        .field input:focus {
            outline: none;
            border-color: #5f83cb;
            box-shadow: 0 0 0 4px rgba(95, 131, 203, 0.2);
        }

        .field-wrap {
            position: relative;
        }

        .field-wrap.has-toggle input {
            padding-right: 46px;
        }

        .field-icon {
            position: absolute;
            top: 50%;
            left: 16px;
            transform: translateY(-50%);
            color: #2d3548;
            font-size: 1.05rem;
            pointer-events: none;
            z-index: 2;
        }

        .password-toggle {
            position: absolute;
            top: 50%;
            right: 14px;
            transform: translateY(-50%);
            border: none;
            background: transparent;
            color: #596885;
            cursor: pointer;
            padding: 0;
            line-height: 1;
        }

        .remember-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 1rem;
            margin: 10px 0 14px;
            color: #44516b;
        }

        .remember-row a {
            color: #30456d;
            font-weight: 600;
            text-decoration: none;
        }

        .remember-row a:hover {
            text-decoration: underline;
        }

        .btn-submit {
            width: 100%;
            border: none;
            border-radius: 999px;
            padding: 13px 16px;
            background: linear-gradient(180deg, #f6d35e 0%, #f0c73f 100%);
            color: var(--accent-ink);
            font-weight: 800;
            font-size: 1.2rem;
            letter-spacing: 0.01em;
            box-shadow: 0 12px 20px rgba(200, 153, 12, 0.26);
        }

        .btn-submit:hover {
            filter: brightness(0.97);
        }

        .helper-links {
            margin-top: 12px;
            font-size: 0.96rem;
            display: flex;
            justify-content: space-between;
            gap: 10px;
        }

        .helper-links a {
            color: #3f4f6f;
            font-weight: 600;
            text-decoration: none;
        }

        .helper-links a:hover {
            text-decoration: underline;
        }

        .auth-image-pane {
            position: relative;
            min-height: 100%;
            height: 100%;
            background: #e7ebf2;
            overflow: hidden;
        }

        .auth-image-pane img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: center center;
            display: block;
        }

        .auth-image-pane::after {
            content: "";
            position: absolute;
            inset: 0;
            background:
                linear-gradient(190deg, rgba(16, 26, 47, 0.1) 8%, rgba(15, 24, 39, 0.42) 100%),
                linear-gradient(0deg, rgba(0, 0, 0, 0.2), transparent 45%);
        }

        .image-caption {
            position: absolute;
            left: 24px;
            bottom: 16px;
            z-index: 2;
            color: #f6f8ff;
            max-width: 80%;
        }

        .image-caption h2 {
            font-family: "Fraunces", serif;
            margin: 0 0 8px;
            font-size: clamp(1.5rem, 1vw + 1.2rem, 2rem);
            letter-spacing: -0.01em;
        }

        .image-caption p {
            margin: 0;
            font-size: 0.95rem;
            color: rgba(246, 248, 255, 0.9);
        }

        .validation-summary-errors ul {
            margin: 0 0 10px;
            padding-left: 16px;
            color: #b4232d;
            font-size: 0.82rem;
        }

        @@media (max-width: 980px) {
            .auth-shell {
                grid-template-columns: 1fr;
                height: auto;
            }

            .auth-image-pane {
                min-height: 280px;
                order: -1;
            }

            .auth-form-pane {
                padding: 26px 22px 22px;
            }

            .auth-form-card {
                padding: 18px 16px 14px;
            }

            .image-caption {
                left: 16px;
                right: 16px;
                bottom: 16px;
                max-width: none;
            }

            .auth-image-pane img {
                object-position: left center;
            }
        }

        @@media (max-width: 520px) {
            body {
                padding: 8px;
            }

            .auth-shell {
                border-radius: 18px;
            }

            .auth-form-pane {
                padding: 20px 16px;
            }

            .form-subtitle {
                font-size: 0.95rem;
            }

            .remember-row {
                font-size: 0.85rem;
                flex-wrap: wrap;
                row-gap: 8px;
            }
        }

        @@media (min-width: 1600px) {
            .auth-shell {
                width: min(1160px, 100%);
                height: min(86vh, 780px);
            }

            .auth-form-card {
                max-width: 600px;
                padding: 28px 28px 20px;
            }

            .form-title {
                font-size: 3.1rem;
            }

            .form-subtitle {
                font-size: 1.2rem;
            }

            .field input {
                font-size: 1.12rem;
            }
        }
    </style>
</head>
<body>
    <div class="auth-shell">
        <section class="auth-form-pane">
            <div class="auth-form-card">
                <div class="brand-badge">FurniComply</div>
                <h1 class="form-title">Sign in</h1>
                <p class="form-subtitle">Access your compliance workspace.</p>

                <form action="/Account/Login" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ReturnUrl" />

                    <div asp-validation-summary="All" class="text-danger small mb-2"></div>

                    <div class="field">
                        <label class="field-label" asp-for="Email">Email Address</label>
                        <div class="field-wrap">
                            <i class="fa-solid fa-envelope field-icon"></i>
                            <input asp-for="Email" placeholder="Email address" />
                        </div>
                    </div>
                    <div class="field">
                        <label class="field-label" asp-for="Password">Password</label>
                        <div class="field-wrap has-toggle">
                            <i class="fa-solid fa-lock field-icon"></i>
                            <input asp-for="Password" id="login-password" type="password" placeholder="Password" />
                            <button type="button" class="password-toggle" id="toggle-password" aria-label="Show password">
                                <i class="fa-regular fa-eye" id="toggle-password-icon"></i>
                            </button>
                        </div>
                    </div>

                    <div class="remember-row">
                        <label class="d-flex align-items-center gap-2 mb-0">
                            <input asp-for="RememberMe" type="checkbox" />
                            Remember me
                        </label>
                        <a href="#">Forgot password?</a>
                    </div>

                    <button class="btn-submit" type="submit">Sign In</button>
                </form>

                <div class="helper-links">
                    <a href="/Home/Index"><i class="fa-solid fa-arrow-left"></i> Back to Home</a>
                    <a href="/Home/RequestAccess">Request Access</a>
                </div>
            </div>
        </section>

        <section class="auth-image-pane" aria-hidden="true">
            <img src="~/images/loginpage-optimized.jpg?v=20260304a"
                 srcset="~/images/loginpage-mobile.jpg?v=20260304a 900w, ~/images/loginpage-optimized.jpg?v=20260304a 1920w"
                 sizes="(max-width: 980px) 100vw, 55vw"
                 alt="Login visual" />
            <div class="image-caption">
                <h2>FurniComply Platform</h2>
                <p>End-to-end governance for supplier compliance, policy control, and procurement risk.</p>
            </div>
        </section>
    </div>
    <script>
        (function () {
            const passwordInput = document.getElementById("login-password");
            const toggleButton = document.getElementById("toggle-password");
            const icon = document.getElementById("toggle-password-icon");
            if (!passwordInput || !toggleButton || !icon) return;

            toggleButton.addEventListener("click", function () {
                const isHidden = passwordInput.type === "password";
                passwordInput.type = isHidden ? "text" : "password";
                icon.classList.toggle("fa-eye", !isHidden);
                icon.classList.toggle("fa-eye-slash", isHidden);
                toggleButton.setAttribute("aria-label", isHidden ? "Hide password" : "Show password");
            });
        })();
    </script>
</body>
</html>
