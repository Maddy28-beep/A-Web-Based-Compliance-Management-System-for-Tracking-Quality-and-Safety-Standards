@model FurniComply.Domain.Entities.SecurityLog

@{
    ViewData["Title"] = "Security Log Details";
    TimeZoneInfo tz;
    try
    {
        tz = TimeZoneInfo.FindSystemTimeZoneById("Asia/Manila");
    }
    catch
    {
        try
        {
            tz = TimeZoneInfo.FindSystemTimeZoneById("Singapore Standard Time");
        }
        catch
        {
            tz = TimeZoneInfo.Local;
        }
    }

    var localTimestamp = TimeZoneInfo.ConvertTimeFromUtc(Model.TimestampUtc, tz);
    var canViewSensitiveFields = (bool?)ViewBag.CanViewSensitiveFields ?? false;
}

<section class="hero">
    <div>
        <p class="eyebrow">Security Monitoring</p>
        <h1>@Model.Category</h1>
        <p class="lede">@Model.Action - @localTimestamp.ToString("yyyy-MM-dd hh:mm tt") PHT</p>
    </div>
    <div class="hero-actions">
        <a class="btn btn-outline-secondary" asp-action="Index"><i class="fa-solid fa-arrow-left"></i> Back</a>
    </div>
</section>

<div class="detail-card">
    <dl>
        <dt>Actor</dt>
        <dd>@Model.Actor</dd>
        <dt>User Id</dt>
        <dd>@(canViewSensitiveFields ? Model.UserId : "Restricted")</dd>
        <dt>IP Address</dt>
        <dd>@(canViewSensitiveFields ? Model.IpAddress : "Restricted")</dd>
        <dt>Details</dt>
        <dd>@(canViewSensitiveFields ? Model.Details : "Restricted for your role")</dd>
    </dl>
</div>
