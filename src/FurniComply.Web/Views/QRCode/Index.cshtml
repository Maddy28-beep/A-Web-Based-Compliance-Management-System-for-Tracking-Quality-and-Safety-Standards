@{
    ViewData["Title"] = "Your Login QR Code";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body text-center">
                <h4 class="mb-3">
                    <i class="fa-solid fa-qrcode me-2"></i>Your Login QR Code
                </h4>
                
                <div id="qrLoading" style="display: none;">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="mt-2">Generating QR code...</p>
                </div>
                
                <div id="qrInitial" class="text-center py-5">
                    <i class="fa-solid fa-qrcode fa-3x text-muted mb-3"></i>
                    <p class="text-muted mb-4">Generate your personal QR code for quick access</p>
                    <button type="button" class="btn btn-primary" onclick="generateQRCode()">
                        <i class="fa-solid fa-qrcode me-2"></i>Generate QR Code
                    </button>
                </div>
                
                <div id="qrResult" style="display: none;">
                    <img id="qrImage" src="" alt="Your Login QR Code" class="img-fluid mb-4" style="max-width: 250px;">
                    
                    <div class="mb-3">
                        <label class="form-label">Your Login Code:</label>
                        <div class="input-group">
                            <input type="text" id="qrText" class="form-control text-center fw-bold" readonly style="font-family: monospace;">
                            <button class="btn btn-outline-secondary" onclick="copyQRCode()">
                                <i class="fa-solid fa-copy"></i>
                            </button>
                        </div>
                    </div>
                    
                    <div class="d-grid gap-2">
                        <button type="button" class="btn btn-success" onclick="downloadQR()">
                            <i class="fa-solid fa-download me-2"></i>Download QR Code
                        </button>
                        <button type="button" class="btn btn-outline-primary" onclick="generateQRCode()">
                            <i class="fa-solid fa-sync me-2"></i>Generate New QR Code
                        </button>
                    </div>
                </div>
                
                <div id="qrError" class="alert alert-danger mt-3" style="display: none;">
                    <i class="fa-solid fa-exclamation-triangle me-2"></i>
                    <span id="qrErrorMessage"></span>
                </div>
            </div>
        </div>
        
        <div class="card mt-3">
            <div class="card-body">
                <h6 class="mb-3">How to use your QR code:</h6>
                <div class="row text-center">
                    <div class="col-4">
                        <i class="fa-solid fa-mobile-alt fa-2x text-primary mb-2"></i>
                        <p class="small mb-0">Screenshot to phone</p>
                    </div>
                    <div class="col-4">
                        <i class="fa-solid fa-print fa-2x text-primary mb-2"></i>
                        <p class="small mb-0">Print for wallet</p>
                    </div>
                    <div class="col-4">
                        <i class="fa-solid fa-bookmark fa-2x text-primary mb-2"></i>
                        <p class="small mb-0">Save for later</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function generateQRCode() {
            $('#qrInitial').hide();
            $('#qrLoading').show();
            $('#qrResult').hide();
            $('#qrError').hide();
            
            $.ajax({
                url: '@Url.Action("GenerateLoginQR", "QRCode")',
                type: 'GET',
                success: function(response) {
                    if (response.success) {
                        $('#qrImage').attr('src', 'data:image/png;base64,' + response.qrCode);
                        $('#qrText').val(response.qrText);
                        $('#qrLoading').hide();
                        $('#qrResult').show();
                    } else {
                        $('#qrErrorMessage').text(response.message || 'Error generating QR code');
                        $('#qrLoading').hide();
                        $('#qrError').show();
                    }
                },
                error: function() {
                    $('#qrErrorMessage').text('Error generating QR code. Please try again.');
                    $('#qrLoading').hide();
                    $('#qrError').show();
                }
            });
        }

        function copyQRCode() {
            var qrText = $('#qrText').val();
            navigator.clipboard.writeText(qrText).then(function() {
                var copyBtn = $('button[onclick="copyQRCode()"]');
                copyBtn.html('<i class="fa-solid fa-check"></i> Copied!');
                copyBtn.removeClass('btn-outline-secondary').addClass('btn-success');
                
                setTimeout(function() {
                    copyBtn.html('<i class="fa-solid fa-copy"></i>');
                    copyBtn.removeClass('btn-success').addClass('btn-outline-secondary');
                }, 2000);
            });
        }

        function downloadQR() {
            var img = $('#qrImage')[0];
            var link = document.createElement('a');
            link.download = 'FurniComply-Login-QR.png';
            link.href = img.src;
            link.click();
        }
    </script>
}
