@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Password updated - FurniComply</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&family=Fraunces:opsz,wght@9..144,700&display=swap" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        :root { --ink: #2f1f17; --glass: rgba(255, 255, 255, 0.72); }
        body {
            min-height: 100vh; margin: 0; display: flex; align-items: center; justify-content: center; padding: 12px;
            font-family: "Manrope", sans-serif; color: var(--ink);
            background: linear-gradient(rgba(26, 16, 12, 0.28), rgba(26, 16, 12, 0.28)),
                url('/images/loginpage-optimized.jpg?v=20260304a') center/cover no-repeat;
        }
        .auth-card {
            width: min(480px, 100%); border-radius: 24px; background: var(--glass);
            border: 1px solid rgba(255, 255, 255, 0.4); backdrop-filter: blur(20px);
            padding: 1.75rem; box-shadow: 0 24px 64px rgba(19, 14, 10, 0.28);
        }
        h1 { font-family: "Fraunces", serif; font-size: 1.75rem; }
    </style>
</head>
<body>
    <main class="auth-card">
        <h1>Password updated</h1>
        <p class="mt-3 mb-4" style="color: #5f4a3f;">
            Your password has been changed. You can now sign in with your new password.
        </p>
        <a asp-action="Login" asp-controller="Account" class="btn btn-lg w-100 fw-bold text-white border-0" style="border-radius: 12px; background-image: linear-gradient(135deg, #1f5a45, #2b8a5a);">Sign in</a>
    </main>
</body>
</html>
