@model ResetPasswordViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>New password - FurniComply</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&family=Fraunces:opsz,wght@9..144,700&display=swap" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        :root { --accent: #1f5a45; --ink: #2f1f17; --glass: rgba(255, 255, 255, 0.72); }
        html, body { height: 100%; margin: 0; font-family: "Manrope", sans-serif; color: var(--ink); }
        body {
            min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 12px;
            background: linear-gradient(rgba(26, 16, 12, 0.28), rgba(26, 16, 12, 0.28)),
                url('/images/loginpage-optimized.jpg?v=20260304a') center/cover no-repeat;
        }
        .auth-card {
            width: min(440px, 100%); border-radius: 24px; background: var(--glass);
            border: 1px solid rgba(255, 255, 255, 0.4); backdrop-filter: blur(20px);
            padding: 1.75rem; box-shadow: 0 24px 64px rgba(19, 14, 10, 0.28);
        }
        h1 { font-family: "Fraunces", serif; font-size: 1.85rem; margin: 0 0 0.5rem; }
        .lede { color: #5f4a3f; font-size: 0.9rem; margin-bottom: 1.25rem; }
        .btn-accent {
            background: linear-gradient(135deg, #1f5a45 0%, #2b8a5a 100%);
            color: #fff; font-weight: 800; border: 0; border-radius: 12px; padding: 0.65rem 1rem;
        }
        .validation { color: #8a1f1f; font-size: 0.88rem; }
        .password-wrap { position: relative; }
        .password-wrap .form-control { padding-right: 3.5rem; }
        .password-toggle {
            position: absolute; top: 50%; right: 0.85rem; transform: translateY(-50%);
            border: 0; background: transparent; color: var(--accent); font-weight: 700;
        }
        .password-toggle:hover { color: #163f31; }
    </style>
</head>
<body>
    <main class="auth-card">
        <h1>Choose a new password</h1>
        <p class="lede">Your new password must meet the site’s strength rules (at least 12 characters, including upper and lower case, a number, and a symbol).</p>

        <form asp-action="ResetPassword" asp-controller="Account" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Email" />
            <input type="hidden" asp-for="Code" />
            <div asp-validation-summary="All" class="validation mb-2"></div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label fw-bold small text-uppercase">New password</label>
                <div class="password-wrap">
                    <input asp-for="Password" class="form-control form-control-lg" autocomplete="new-password" />
                    <button type="button" class="password-toggle" data-toggle-password="#Password">Show</button>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label fw-bold small text-uppercase">Confirm</label>
                <div class="password-wrap">
                    <input asp-for="ConfirmPassword" class="form-control form-control-lg" autocomplete="new-password" />
                    <button type="button" class="password-toggle" data-toggle-password="#ConfirmPassword">Show</button>
                </div>
            </div>
            <button type="submit" class="btn btn-accent w-100">Update password</button>
        </form>

        <p class="text-center small mt-3 mb-0">
            <a asp-action="Login" asp-controller="Account" class="fw-bold text-decoration-none" style="color: var(--accent);">Back to sign in</a>
        </p>
    </main>
    <script>
        document.querySelectorAll("[data-toggle-password]").forEach(function (button) {
            button.addEventListener("click", function () {
                var input = document.querySelector(button.getAttribute("data-toggle-password"));
                if (!input) return;
                var showing = input.type === "text";
                input.type = showing ? "password" : "text";
                button.textContent = showing ? "Show" : "Hide";
            });
        });
    </script>
</body>
</html>
