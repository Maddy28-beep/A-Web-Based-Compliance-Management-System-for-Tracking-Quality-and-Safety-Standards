@model ForgotPasswordViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot password - FurniComply</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&family=Fraunces:opsz,wght@9..144,700&display=swap" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <style>
        :root { --accent: #1f5a45; --ink: #2f1f17; --glass: rgba(255, 255, 255, 0.72); }
        html, body { height: 100%; margin: 0; font-family: "Manrope", sans-serif; color: var(--ink); }
        body {
            min-height: 100vh;
            display: flex; align-items: center; justify-content: center; padding: 12px;
            background: linear-gradient(rgba(26, 16, 12, 0.28), rgba(26, 16, 12, 0.28)),
                url('/images/loginpage-optimized.jpg?v=20260304a') center/cover no-repeat;
        }
        .auth-card {
            width: min(440px, 100%);
            border-radius: 24px;
            background: var(--glass);
            border: 1px solid rgba(255, 255, 255, 0.4);
            backdrop-filter: blur(20px);
            padding: 1.75rem;
            box-shadow: 0 24px 64px rgba(19, 14, 10, 0.28);
        }
        h1 { font-family: "Fraunces", serif; font-size: 1.85rem; margin: 0 0 0.5rem; }
        .lede { color: #5f4a3f; font-size: 0.9rem; margin-bottom: 1.25rem; }
        .btn-accent {
            background: linear-gradient(135deg, #1f5a45 0%, #2b8a5a 100%);
            color: #fff; font-weight: 800; border: 0; border-radius: 12px; padding: 0.65rem 1rem;
        }
        .btn-accent:hover { filter: brightness(0.95); color: #fff; }
        .validation { color: #8a1f1f; font-size: 0.88rem; }
    </style>
</head>
<body>
    <main class="auth-card">
        <div class="d-flex align-items-center gap-2 mb-3">
            <img src="~/images/logo.png" alt="" width="40" height="40" />
            <span class="fw-bold fs-5">FurniComply</span>
        </div>
        <h1>Reset your password</h1>
        <p class="lede">Enter your email and we’ll send you a link to choose a new password.</p>

        <form asp-action="ForgotPassword" asp-controller="Account" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="validation mb-2"></div>
            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-bold small text-uppercase">Email</label>
                <input asp-for="Email" class="form-control form-control-lg" autocomplete="email" placeholder="you@organization.edu" />
            </div>
            <partial name="_RecaptchaWidget" />
            <button type="submit" class="btn btn-accent w-100">Send reset link</button>
        </form>

        <p class="text-center small mt-3 mb-0">
            <a asp-action="Login" asp-controller="Account" class="fw-bold text-decoration-none" style="color: var(--accent);">Back to sign in</a>
        </p>
    </main>
</body>
</html>
