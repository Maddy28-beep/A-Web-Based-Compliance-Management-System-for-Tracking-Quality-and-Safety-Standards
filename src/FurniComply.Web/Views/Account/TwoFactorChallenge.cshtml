@model FurniComply.Web.Models.TwoFactorChallengeViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Two-Factor Authentication - FurniComply</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
</head>
<body class="bg-light d-flex align-items-center min-vh-100">
    <div class="container" style="max-width: 400px;">
        <div class="card shadow">
            <div class="card-body p-4">
                <h4 class="card-title mb-3"><i class="fa-solid fa-shield-halved text-primary me-2"></i>Two-Factor Authentication</h4>
                <p class="text-muted small">Enter the 6-digit code from your authenticator app.</p>
                <form asp-action="TwoFactorChallenge" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ReturnUrl" />
                    <input type="hidden" asp-for="RememberMe" />
                    <input type="hidden" asp-for="RememberMachine" />
                    <div asp-validation-summary="All" class="text-danger small mb-2"></div>
                    <div class="mb-3">
                        <label asp-for="Code" class="form-label">Verification Code</label>
                        <input asp-for="Code" class="form-control form-control-lg" placeholder="000000" autocomplete="one-time-code" maxlength="7" />
                    </div>
                    <div class="mb-2 form-check">
                        <input asp-for="RememberMachine" class="form-check-input" />
                        <label asp-for="RememberMachine" class="form-check-label small">Trust this device for 30 days</label>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Verify</button>
                </form>
                <p class="mt-3 mb-0 small text-muted"><a asp-action="Login">← Back to login</a></p>
            </div>
        </div>
    </div>
</body>
</html>
