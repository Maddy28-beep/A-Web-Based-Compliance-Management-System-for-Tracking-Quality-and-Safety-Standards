@model FurniComply.Domain.Entities.RegulatoryReport
@{
    Layout = null;
    var now = ((DateTime?)ViewBag.GeneratedAtUtc ?? DateTime.UtcNow).ToLocalTime();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FurniComply Regulatory Report</title>
    <style>
        :root {
            --ink: #1f2623;
            --muted: #5c6861;
            --brand: #0f3b2f;
            --paper: #fcfbf7;
            --line: #d6ddd8;
        }
        * { box-sizing: border-box; }
        body {
            margin: 0;
            color: var(--ink);
            font-family: "Segoe UI", "Trebuchet MS", sans-serif;
            background: linear-gradient(140deg, #edf2ef 0%, #f8f4ea 100%);
        }
        .sheet {
            width: 100%;
            max-width: 920px;
            margin: 22px auto;
            background: var(--paper);
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 28px;
        }
        .head {
            border-bottom: 2px solid var(--line);
            padding-bottom: 14px;
            margin-bottom: 16px;
        }
        .kicker {
            font-size: 12px;
            letter-spacing: .18em;
            text-transform: uppercase;
            color: #51697b;
            font-weight: 700;
        }
        h1 {
            margin: 6px 0 8px;
            font-family: "Georgia", "Times New Roman", serif;
            font-size: 34px;
            line-height: 1.1;
        }
        .meta {
            color: var(--muted);
            font-size: 13px;
        }
        .actions {
            display: flex;
            gap: 10px;
            margin-bottom: 16px;
        }
        .btn {
            border: 1px solid #0f3b2f;
            color: #0f3b2f;
            background: white;
            padding: 10px 14px;
            border-radius: 10px;
            font-weight: 600;
            text-decoration: none;
            cursor: pointer;
        }
        .btn.primary {
            background: #0f3b2f;
            color: #fff;
        }
        .grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-bottom: 14px;
        }
        .field {
            border: 1px solid var(--line);
            border-radius: 10px;
            background: #fff;
            padding: 12px;
        }
        .field small {
            display: block;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: .06em;
            font-size: 11px;
        }
        .field strong {
            display: block;
            margin-top: 4px;
            font-size: 17px;
            line-height: 1.3;
        }
        .summary {
            border: 1px solid var(--line);
            border-radius: 10px;
            background: #fff;
            padding: 14px;
            min-height: 160px;
            white-space: pre-wrap;
            line-height: 1.45;
        }
        @@media print {
            body { background: #fff; }
            .sheet { margin: 0; border: 0; border-radius: 0; padding: 0; max-width: none; }
            .actions { display: none; }
        }
    </style>
</head>
<body>
    <div class="sheet">
        <div class="head">
            <div class="kicker">FurniComply</div>
            <h1>Regulatory Report</h1>
            <div class="meta">Generated: @now.ToString("yyyy-MM-dd hh:mm tt") local time</div>
        </div>

        <div class="actions">
            <button class="btn primary" onclick="window.print()">Print / Save as PDF</button>
            <a class="btn" href="/RegulatoryReports"><i class="fa-solid fa-arrow-left"></i> Back to Reports</a>
        </div>

        <div class="grid">
            <div class="field"><small>Report Type</small><strong>@Model.ReportType</strong></div>
            <div class="field"><small>Supplier</small><strong>@(Model.Supplier?.Name ?? "-")</strong></div>
            <div class="field"><small>Status</small><strong>@(Model.ReportStatus?.Name ?? "-")</strong></div>
            <div class="field"><small>Submitted</small><strong>@(Model.SubmittedAtUtc?.ToString("yyyy-MM-dd") ?? "-")</strong></div>
            <div class="field"><small>Period Start</small><strong>@Model.PeriodStartUtc.ToString("yyyy-MM-dd")</strong></div>
            <div class="field"><small>Period End</small><strong>@Model.PeriodEndUtc.ToString("yyyy-MM-dd")</strong></div>
        </div>

        <div class="field">
            <small>Executive Summary</small>
            <div class="summary">@(string.IsNullOrWhiteSpace(Model.Summary) ? "-" : Model.Summary)</div>
        </div>
    </div>
</body>
</html>
