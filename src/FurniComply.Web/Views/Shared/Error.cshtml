@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<h1 class="text-danger">Error</h1>
<h2 class="text-secondary">Something went wrong. Please try again.</h2>
<p>If the problem persists, check the application logs or contact your administrator.</p>
@if (Model.ShowRequestId)
{
    <p class="mt-3">
        <small>Reference: <code>@Model.RequestId</code></small>
    </p>
}
