@model FurniComply.Web.Models.CreateUserViewModel

@{
    ViewData["Title"] = "Create User";
}

<section class="hero">
    <div>
        <p class="eyebrow">Super Admin</p>
        <h1>Create User</h1>
        <p class="lede">Add a new user and assign roles.</p>
    </div>
    <div class="hero-actions">
        <a class="btn btn-outline-secondary" asp-action="Users"><i class="fa-solid fa-arrow-left"></i> Back</a>
    </div>
</section>

<div class="form-card create-user-form">
    <form asp-action="CreateUser" method="post">
        @Html.AntiForgeryToken()
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Email" class="form-label">Email <span class="text-danger">*</span></label>
                <input asp-for="Email" class="form-control" type="email" placeholder="user@furnicomply.local" required />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="FullName" class="form-label">Full Name</label>
                <input asp-for="FullName" class="form-control" placeholder="Juan Dela Cruz" />
            </div>
            <div class="col-md-6">
                <label asp-for="Password" class="form-label">Password <span class="text-danger">*</span></label>
                <input asp-for="Password" class="form-control" type="password" placeholder="Min 12 chars: upper, lower, digit, special" />
                <p class="form-text small text-muted mb-0 mt-1">At least 12 characters with uppercase, lowercase, a digit, and a special character (e.g. &#64;#$%^&amp;*)</p>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="ConfirmPassword" class="form-label">Confirm Password <span class="text-danger">*</span></label>
                <input asp-for="ConfirmPassword" class="form-control" type="password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>
        </div>
        <div class="create-user-roles-section">
            <label class="form-label fw-semibold">Roles</label>
            <select name="SelectedRoles" multiple class="form-select create-user-roles-select no-select2" size="6">
                @foreach (var role in Model.Roles)
                {
                    @if (Model.SelectedRoles?.Contains(role.Name) == true)
                    {
                        <option value="@role.Name" selected>@role.Name</option>
                    }
                    else
                    {
                        <option value="@role.Name">@role.Name</option>
                    }
                }
            </select>
            <p class="form-text small text-muted mt-1 mb-0">Hold Ctrl (Windows) or Cmd (Mac) to select multiple roles.</p>
        </div>
        <div class="create-user-actions">
            <button type="submit" class="btn btn-success">Create User</button>
            <a class="btn btn-outline-secondary" asp-action="Users">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}
