@model FurniComply.Web.Services.MailDiagnosticsViewModel
@{
    ViewData["Title"] = "Mail / SMTP diagnostics";
}

<section class="hero">
    <div>
        <p class="eyebrow">Administration</p>
        <h1>Mail &amp; password reset (SMTP)</h1>
        <p class="lede">Configuration loaded from <code>Mail:*</code> in appsettings. This does not send a test email or show your password.</p>
    </div>
    <div class="hero-actions">
        <a class="btn btn-outline-secondary" asp-action="Users"><i class="fa-solid fa-arrow-left me-1"></i> Back to settings</a>
    </div>
</section>

<div class="table-card">
    <h3 class="table-section-title">Configuration</h3>
    <table class="table data-table">
        <tbody>
        <tr>
            <th style="width:220px;">SMTP host set</th>
            <td>@(Model.SmtpHostConfigured ? "Yes" : "No") @(Model.SmtpHostConfigured ? $"({Model.SmtpHost})" : "")</td>
        </tr>
        <tr>
            <th>Port / TLS</th>
            <td>@Model.SmtpPort — UseSsl: @Model.UseSsl</td>
        </tr>
        <tr>
            <th>From</th>
            <td>@(string.IsNullOrEmpty(Model.From) ? "—" : Model.From)</td>
        </tr>
        <tr>
            <th>UserName</th>
            <td>@(string.IsNullOrEmpty(Model.UserName) ? "—" : Model.UserName)</td>
        </tr>
        <tr>
            <th>Password</th>
            <td>@(Model.PasswordPresent ? $"Present (length {Model.PasswordLength})" : "Missing")</td>
        </tr>
        <tr>
            <th>Looks complete</th>
            <td>
                @if (Model.ConfigurationLooksComplete)
                {
                    <span class="text-success fw-bold">Yes — host, from, username, and password are non-empty.</span>
                }
                else
                {
                    <span class="text-danger fw-bold">No — fill in Mail settings in appsettings or User Secrets.</span>
                }
            </td>
        </tr>
        </tbody>
    </table>
</div>

<div class="table-card mt-3">
    <h3 class="table-section-title">Network check (TCP)</h3>
    <p class="text-muted small mb-2">Proves the server accepts connections on the SMTP port. It does <strong>not</strong> confirm Microsoft 365 will accept your login.</p>
    @if (Model.TcpConnectSucceeded == true)
    {
        <div class="alert alert-success mb-0">@Model.TcpConnectDetail</div>
    }
    else if (Model.TcpConnectSucceeded == false)
    {
        <div class="alert alert-warning mb-0"><strong>Could not connect.</strong> @Model.TcpConnectDetail</div>
    }
    else
    {
        <div class="alert alert-secondary mb-0">@Model.TcpConnectDetail</div>
    }
</div>

<div class="table-card mt-3">
    <h3 class="table-section-title">Send test email</h3>
    @if (TempData["MailTestSuccess"] is string success)
    {
        <div class="alert alert-success">@success</div>
    }
    @if (TempData["MailTestError"] is string mailError)
    {
        <div class="alert alert-danger">@mailError</div>
    }
    <p class="text-muted small">Uses the same SMTP settings as password reset. <code>Mail:From</code> is the Gmail account that sends mail; it can differ from your login email.</p>
    <form asp-action="SendTestEmail" method="post" class="row g-2 align-items-end">
        @Html.AntiForgeryToken()
        <div class="col-md-8">
            <label class="form-label" for="testEmail">Send test to</label>
            <input type="email" class="form-control" id="testEmail" name="testEmail" placeholder="you@example.com" required />
        </div>
        <div class="col-md-4">
            <button type="submit" class="btn btn-primary w-100"><i class="fa-solid fa-paper-plane me-1"></i> Send test</button>
        </div>
    </form>
</div>

<div class="table-card mt-3">
    <h3 class="table-section-title">Notes</h3>
    <ul class="mb-0">
        @foreach (var note in Model.Notes)
        {
            <li>@note</li>
        }
    </ul>
</div>
