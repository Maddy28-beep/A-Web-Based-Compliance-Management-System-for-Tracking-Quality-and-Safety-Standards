@model IEnumerable<FurniComply.Domain.Entities.ProcurementOrder>

@{
    ViewData["Title"] = "Procurement Orders";
    var canManageOrders = User.IsInRole(FurniComply.Infrastructure.Identity.RoleNames.Procurement) &&
        !User.IsInRole(FurniComply.Infrastructure.Identity.RoleNames.SuperAdmin);
}

<header class="hero">
    <div>
        <p class="eyebrow">Procurement</p>
        <h1>Purchase Orders</h1>
        <p class="lede">Track order lifecycle, totals, and supplier alignment.</p>
        <div class="page-meta" aria-label="Page context">
            <span class="meta-pill"><i class="fa-solid fa-clock"></i> Dates shown in local time</span>
            <span class="meta-pill"><i class="fa-solid fa-table-list"></i> @Model.Count() total</span>
        </div>
    </div>
    <div class="hero-actions">
        @if (canManageOrders)
        {
            <a class="btn btn-outline-secondary" asp-action="Archived"><i class="fa-solid fa-box-archive"></i> Archived</a>
            <a class="btn btn-success btn-lg px-4" asp-action="Create"><i class="fa-solid fa-plus"></i> Create Order</a>
        }
    </div>
</header>

@if (ViewBag.HasComplianceApprovalBlocker is bool hasComplianceBlocker && hasComplianceBlocker)
{
    <article class="notice notice-warning" role="status" aria-live="polite">
        <i class="fa-solid fa-circle-exclamation"></i>
        <div>
            <strong>Approval guard active</strong>
            <p>There are unresolved CAPA items from non-compliant checks. Draft POs cannot be approved until CAPA is closed.</p>
        </div>
        <button type="button" class="notice-close" aria-label="Dismiss message">
            <i class="fa-solid fa-xmark"></i>
        </button>
    </article>
}

@if (!Model.Any())
{
    <section class="empty-state" aria-label="No purchase orders">
        <div class="empty-state-icon"><i class="fa-solid fa-truck-field"></i></div>
        <div>
            <h3>No orders yet</h3>
            <p>Create a purchase order to start tracking totals, supplier alignment, and approval status.</p>
            <div class="empty-state-actions">
                @if (canManageOrders)
                {
                    <a class="btn btn-success" asp-action="Create"><i class="fa-solid fa-plus"></i> Create Order</a>
                    <a class="btn btn-outline-secondary" asp-action="Archived"><i class="fa-solid fa-box-archive"></i> View Archived</a>
                }
            </div>
        </div>
    </section>
}
else
{
    <div class="table-card">
        <div class="table-card-header">
            <div>
                <h3 class="table-card-title">Order Approval Queue</h3>
                <p class="table-card-subtitle">Click a row to open details. Draft orders may require approval actions.</p>
            </div>
        </div>
        <table class="table data-table order-queue-table">
        <thead>
            <tr>
                <th class="col-order-number">Order #</th>
                <th class="table-cell-left col-order-total">Total</th>
                <th class="col-supplier">Supplier</th>
                <th class="col-status table-cell-center">Status</th>
                <th class="col-order-date table-cell-center">Date</th>
                @if (canManageOrders)
                {
                    <th class="table-cell-center col-order-actions">Actions</th>
                }
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr data-href="@Url.Action("Details", new { id = item.Id })">
                <td class="text-truncate-150 col-order-number">@item.OrderNumber</td>
                <td class="table-cell-left col-order-total text-nowrap">₱@item.TotalAmount.ToString("N2")</td>
                <td class="text-truncate-200 col-supplier">@item.Supplier?.Name</td>
                <td class="col-status table-cell-center">
                    @{
                        var statusName = item.ProcurementStatus?.Name ?? "Unknown";
                        var badgeClass = statusName switch
                        {
                            "Draft" => "bg-secondary",
                            "Submitted" => "bg-primary",
                            "Approved" => "bg-success",
                            "Ordered" => "bg-success",
                            "Received" => "bg-success",
                            "Rejected" => "bg-danger",
                            "Cancelled" => "bg-danger",
                            "Closed" => "bg-dark",
                            _ => "bg-warning text-dark"
                        };
                    }
                    <span class="badge @badgeClass @(statusName == "Ordered" ? "badge-ordered" : "")">@statusName.ToUpper()</span>
                </td>
                <td class="col-order-date table-cell-center">@item.OrderDateUtc.ToString("yyyy-MM-dd")</td>
                @if (canManageOrders)
                {
                    <td class="actions-cell col-order-actions">
                        <a class="icon-action text-warning" asp-action="Edit" asp-route-id="@item.Id" title="Edit"><i class="fa-solid fa-pen"></i></a>
                        <form asp-action="Delete" method="post" class="d-inline" data-confirm="delete">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="icon-action text-danger" aria-label="Archive order" title="Archive">
                                <i class="fa-solid fa-box-archive"></i>
                            </button>
                        </form>
                    </td>
                }
            </tr>
        }
        </tbody>
        </table>
    </div>
}

@section Scripts {
    <script>
        $(function () {
            var hasActions = @(canManageOrders ? "true" : "false");
            var colDefs = hasActions
                ? [
                    { targets: 0, width: "14%" },
                    { targets: 1, width: "12%" },
                    { targets: 2, width: "26%" },
                    { targets: 3, width: "16%" },
                    { targets: 4, width: "16%" },
                    { targets: 5, width: "16%", orderable: false, searchable: false }
                ]
                : [
                    { targets: 0, width: "15%" },
                    { targets: 1, width: "15%" },
                    { targets: 2, width: "35%" },
                    { targets: 3, width: "17%" },
                    { targets: 4, width: "18%" }
                ];

            $('.order-queue-table').DataTable({
                autoWidth: false,
                order: [[4, 'desc']],
                columnDefs: colDefs
            });
        });
    </script>
}
