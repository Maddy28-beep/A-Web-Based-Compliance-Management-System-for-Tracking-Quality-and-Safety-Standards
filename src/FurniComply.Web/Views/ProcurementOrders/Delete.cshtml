@model FurniComply.Domain.Entities.ProcurementOrder

@{
    ViewData["Title"] = "Archive Order";
}

<header class="page-header">
    <div>
        <p class="eyebrow">Procurement</p>
        <h1>Archive Purchase Order</h1>
        <p class="lede">This archives the record and can be restored later.</p>
        <div class="page-meta" aria-label="Page context">
            <span class="meta-pill"><i class="fa-solid fa-triangle-exclamation"></i> Destructive action</span>
        </div>
    </div>
    <div class="page-header-actions">
        <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.Id"><i class="fa-solid fa-arrow-left"></i> Back</a>
    </div>
</header>

<div class="form-card">
    <h3 style="margin-top:0;">@Model.OrderNumber</h3>
    <p class="section-meta">Supplier: @(Model.Supplier?.Name ?? "-") · Status: @(Model.ProcurementStatus?.Name ?? "-")</p>
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="empty-state" style="margin-top: 14px;">
            <div class="empty-state-icon"><i class="fa-solid fa-box-archive"></i></div>
            <div>
                <h3>Archive this purchase order?</h3>
                <p>This is a soft delete. The purchase order will move to <strong>Archived</strong> and can be restored later.</p>
                <div class="empty-state-actions">
                    <button class="btn btn-outline-danger" type="submit"><i class="fa-solid fa-box-archive"></i> Archive</button>
                    <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.Id">Cancel</a>
                </div>
            </div>
        </div>
    </form>
</div>

