@model FurniComply.Domain.Entities.ProcurementOrder
@using FurniComply.Infrastructure.Identity

@{
    ViewData["Title"] = "Order Details";
    var supplierName = Model.Supplier?.Name ?? "-";
    var statusName = Model.ProcurementStatus?.Name ?? "-";
    var isAdmin = User.IsInRole(RoleNames.Admin);
    var isProcurement = User.IsInRole(RoleNames.Procurement) && !User.IsInRole(RoleNames.SuperAdmin);
}

<header class="hero">
    <div>
        <p class="eyebrow">Procurement</p>
        <h1>@Model.OrderNumber</h1>
        @{
            var badgeClass = statusName switch
            {
                "Draft" => "bg-secondary",
                "Submitted" => "bg-primary",
                "Approved" => "bg-success",
                "Ordered" => "bg-success",
                "Received" => "bg-success",
                "Rejected" => "bg-danger",
                "Cancelled" => "bg-danger",
                "Closed" => "bg-dark",
                _ => "bg-warning text-dark"
            };
            var statusAccentClass = statusName == "Ordered" ? "badge-ordered" : "";
        }
        <p class="lede">Supplier @supplierName · <span class="badge @badgeClass @statusAccentClass">@statusName.ToUpper()</span></p>
        <div class="page-meta" aria-label="Page context">
            <span class="meta-pill"><i class="fa-solid fa-clock"></i> Dates shown in local time</span>
            <span class="meta-pill"><i class="fa-solid fa-flag"></i> @statusName</span>
            <span class="meta-pill"><i class="fa-solid fa-boxes-stacked"></i> @(Model.Items?.Count ?? 0) items</span>
            @if (Model.Supplier?.IsOverrideActive == true)
            {
                <span class="meta-pill"><i class="fa-solid fa-shield-halved"></i> OVERRIDDEN (Documents)</span>
            }
        </div>
    </div>
    <div class="hero-actions">
        <a class="btn btn-outline-secondary" asp-action="Index"><i class="fa-solid fa-arrow-left"></i> Back</a>
        
        @if (isProcurement)
        {
            @if (statusName == "Draft" || statusName == "Rejected")
            {
                <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id"><i class="fa-solid fa-pen"></i> Edit</a>
                <form asp-action="Submit" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-primary"><i class="fa-solid fa-paper-plane"></i> Submit for Approval</button>
                </form>
            }
        }

        @if (User.IsInRole(RoleNames.ComplianceManager))
        {
            @if (statusName == "Approved")
            {
                <form asp-action="PlaceOrder" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-success"><i class="fa-solid fa-truck-fast"></i> Mark as Ordered</button>
                </form>
            }
        }

        @if (isAdmin)
        {
            @if (statusName == "Submitted")
            {
                <form asp-action="Approve" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-success"><i class="fa-solid fa-check"></i> Approve</button>
                </form>
                <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#rejectModal">
                    <i class="fa-solid fa-xmark"></i> Reject
                </button>
            }
        }
    </div>
</header>


@if (Model.Supplier?.IsOverrideActive == true)
{
    <div class="alert alert-warning mb-4">
        <strong>OVERRIDDEN (Documents)</strong><br />
        Reason: @(string.IsNullOrWhiteSpace(Model.Supplier.OverrideReason) ? "-" : Model.Supplier.OverrideReason)<br />
        Approved By: @(string.IsNullOrWhiteSpace(Model.Supplier.OverriddenBy) ? "-" : Model.Supplier.OverriddenBy)
    </div>
}

<div class="row g-4 mb-4">
    <div class="col-md-8">
        <div class="detail-card h-100">
            <h3 class="mb-3">Order Information</h3>
            <dl class="row mb-0">
                <dt class="col-sm-4">Order Date (Local time)</dt>
                <dd class="col-sm-8">@Model.OrderDateUtc.ToLocalTime().ToString("yyyy-MM-dd")</dd>
                
                <dt class="col-sm-4">Total Amount (USD)</dt>
                @if (Model.TotalAmount > 0)
                {
                    <dd class="col-sm-8 font-weight-bold">$@Model.TotalAmount.ToString("N2")</dd>
                    @if (Model.ExchangeRateUsed.HasValue)
                    {
                        <dt class="col-sm-4">Total Amount (PHP)</dt>
                        <dd class="col-sm-8 text-success font-weight-bold">
                            ₱@((Model.TotalAmount * Model.ExchangeRateUsed.Value).ToString("N2"))
                            <div class="small text-muted mt-1">
                                Rate: 1 USD = @Model.ExchangeRateUsed.Value.ToString("N4") PHP
                                <br/>Captured: @(Model.ExchangeRateTimestampUtc.HasValue ? Model.ExchangeRateTimestampUtc.Value.ToLocalTime().ToString("yyyy-MM-dd hh:mm tt") : "-") local time
                            </div>
                        </dd>
                    }
                }
                else
                {
                    <dd class="col-sm-8"><span class="text-muted">— / No items yet</span></dd>
                }
            </dl>
        </div>
    </div>
    <div class="col-md-4">
        <div class="detail-card h-100">
            <h3 class="mb-3">Workflow Guide</h3>
            <div class="workflow-steps">
                <div class="step @(statusName == "Draft" ? "active" : "completed")">
                    <div class="step-icon"><i class="fa-solid fa-file-pen"></i></div>
                    <div class="step-label">Draft</div>
                </div>
                <div class="step-arrow"><i class="fa-solid fa-chevron-down"></i></div>
                <div class="step @(statusName == "Submitted" ? "active" : (statusName == "Approved" || statusName == "Ordered" ? "completed" : (statusName == "Rejected" ? "rejected" : "")))">
                    <div class="step-icon"><i class="fa-solid fa-paper-plane"></i></div>
                    <div class="step-label">Submitted</div>
                </div>
                <div class="step-arrow"><i class="fa-solid fa-chevron-down"></i></div>
                <div class="step @(statusName == "Approved" ? "active" : (statusName == "Ordered" ? "completed" : ""))">
                    <div class="step-icon"><i class="fa-solid fa-check-double"></i></div>
                    <div class="step-label">Approved</div>
                </div>
                <div class="step-arrow"><i class="fa-solid fa-chevron-down"></i></div>
                <div class="step @(statusName == "Ordered" ? "active" : "")">
                    <div class="step-icon"><i class="fa-solid fa-truck-fast"></i></div>
                    <div class="step-label">Ordered</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Rejection Modal -->
<div class="modal fade" id="rejectModal" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="Reject" method="post" class="modal-content">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <div class="modal-header">
                <h5 class="modal-title">Reject Order @Model.OrderNumber</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <label class="form-label">Reason for Rejection</label>
                <textarea name="reason" class="form-control" rows="3" required placeholder="Explain why this order is being rejected..."></textarea>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-danger">Confirm Rejection</button>
            </div>
        </form>
    </div>
</div>

@if (Model.Items == null || !Model.Items.Any())
{
    <section class="empty-state" aria-label="No order items">
        <div class="empty-state-icon"><i class="fa-solid fa-boxes-stacked"></i></div>
        <div>
            <h3>No items yet</h3>
            <p>Add at least one item to compute totals and define quality standards for this purchase order.</p>
            <div class="empty-state-actions">
                @if (isProcurement)
                {
                    <a class="btn btn-success" asp-controller="ProcurementItems" asp-action="Create" asp-route-orderId="@Model.Id"><i class="fa-solid fa-plus"></i> Add Item</a>
                }
            </div>
        </div>
    </section>
}
else
{
    <div class="table-card">
        <div class="table-card-header">
            <div>
                <h3 class="table-card-title">Order Items</h3>
                <p class="table-card-subtitle">Line items and quality standards. Click a row to edit an item.</p>
            </div>
            <div class="table-tools">
                @if (isProcurement)
                {
                    <a class="btn btn-success" asp-controller="ProcurementItems" asp-action="Create" asp-route-orderId="@Model.Id"><i class="fa-solid fa-plus"></i> Add Item</a>
                }
            </div>
        </div>
        <table class="table">
        <thead>
            <tr>
                <th>Item</th>
                <th>Qty</th>
                <th>Unit Cost</th>
                <th>Standard</th>
                @if (isProcurement)
                {
                    <th>Actions</th>
                }
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model.Items)
        {
            <tr data-href="@Url.Action("Edit", "ProcurementItems", new { id = item.Id })">
                <td>@item.ItemName</td>
                <td>@item.Quantity</td>
                <td>$@item.UnitCost.ToString("N2")</td>
                <td>@item.QualityStandard</td>
                @if (isProcurement)
                {
                    <td class="actions-cell">
                        <a class="icon-action text-warning" asp-controller="ProcurementItems" asp-action="Edit" asp-route-id="@item.Id"><i class="fa-solid fa-pen"></i></a>
                        <form asp-controller="ProcurementItems" asp-action="Delete" method="post" class="d-inline" data-confirm="delete">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="icon-action text-danger" aria-label="Archive order item">
                                <i class="fa-solid fa-box-archive"></i>
                            </button>
                        </form>
                    </td>
                }
            </tr>
        }
        </tbody>
        </table>
    </div>
}
