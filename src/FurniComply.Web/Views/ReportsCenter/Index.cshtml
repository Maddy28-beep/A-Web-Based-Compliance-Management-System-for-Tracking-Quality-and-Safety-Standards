@{
    ViewData["Title"] = "Reports Center";
    var isFullAuditOperator =
        User.IsInRole(FurniComply.Infrastructure.Identity.RoleNames.SuperAdmin) ||
        User.IsInRole(FurniComply.Infrastructure.Identity.RoleNames.Admin) ||
        User.IsInRole(FurniComply.Infrastructure.Identity.RoleNames.ComplianceManager) ||
        User.IsInRole(FurniComply.Infrastructure.Identity.RoleNames.Auditor);
    var isScopedAuditViewer =
        User.IsInRole(FurniComply.Infrastructure.Identity.RoleNames.DepartmentHead) ||
        User.IsInRole(FurniComply.Infrastructure.Identity.RoleNames.Procurement);
}

<header class="hero module-header">
    <div>
        <p class="eyebrow">Governance</p>
        <h1>Reports Center</h1>
        <p class="lede">Export-ready reporting workspace with role-based visibility for compliance, audit, and supplier documentation.</p>
    </div>
    <div class="hero-actions module-header-actions">
        <a class="btn btn-outline-secondary btn-back-dashboard" href="/Dashboard/Index"><i class="fa-solid fa-arrow-left"></i> Back to Dashboard</a>
    </div>
</header>

<section class="report-center-grid">
    <article class="table-card report-center-card">
        <div class="table-card-header">
            <div>
                <h3 class="table-card-title">Supplier Performance</h3>
                <p class="table-card-subtitle">Quality ratings, delivery performance, and defect rate trends by supplier.</p>
            </div>
        </div>
        <div class="report-center-actions">
            <a class="btn btn-primary btn-lg px-4" href="/ReportsCenter/SupplierPerformance"><i class="fa-solid fa-star"></i> View Performance</a>
        </div>
    </article>

    <article class="table-card report-center-card">
        <div class="table-card-header">
            <div>
                <h3 class="table-card-title">Regulatory Reports</h3>
                <p class="table-card-subtitle">Submission tracking, approval status, and regulator-ready summaries.</p>
            </div>
        </div>
        <div class="report-center-actions">
            <a class="btn btn-success btn-lg px-4" href="/RegulatoryReports/Index"><i class="fa-solid fa-chart-bar"></i> Open Reports</a>
        </div>
    </article>

    @if (isFullAuditOperator || isScopedAuditViewer)
    {
        <article class="table-card report-center-card">
            <div class="table-card-header">
                <div>
                    <h3 class="table-card-title">@(isScopedAuditViewer && !isFullAuditOperator ? "My Audit Trail" : "Audit Logs")</h3>
                    <p class="table-card-subtitle">@(isScopedAuditViewer && !isFullAuditOperator ? "Review your own recorded actions and approval history." : "Immutable activity trail for approvals, overrides, and key record changes.")</p>
                </div>
            </div>
            <div class="report-center-actions">
                <a class="btn btn-outline-secondary btn-lg px-4" href="/AuditLogs/Index"><i class="fa-solid fa-list-check"></i> View Audit Logs</a>
            </div>
        </article>
    }

    @if (isFullAuditOperator || isScopedAuditViewer)
    {
        <article class="table-card report-center-card">
            <div class="table-card-header">
                <div>
                    <h3 class="table-card-title">@(isScopedAuditViewer && !isFullAuditOperator ? "My Security Activity" : "Security Logs")</h3>
                    <p class="table-card-subtitle">@(isScopedAuditViewer && !isFullAuditOperator ? "Review your login, lockout, and account-security events." : "Login, lockout, password reset, MFA, and other account-security events with IP traceability.")</p>
                </div>
            </div>
            <div class="report-center-actions">
                <a class="btn btn-outline-secondary btn-lg px-4" href="/SecurityLogs/Index"><i class="fa-solid fa-user-shield"></i> View Security Logs</a>
            </div>
        </article>
    }

    <article class="table-card report-center-card">
        <div class="table-card-header">
            <div>
                <h3 class="table-card-title">Compliance Checks</h3>
                <p class="table-card-subtitle">Check-level evidence records with policy, status, and supplier context.</p>
            </div>
        </div>
        <div class="report-center-actions">
            <a class="btn btn-outline-secondary btn-lg px-4" href="/ComplianceChecks/Index"><i class="fa-solid fa-clipboard-check"></i> View Checks</a>
        </div>
    </article>

    <article class="table-card report-center-card">
        <div class="table-card-header">
            <div>
                <h3 class="table-card-title">Supplier Documents</h3>
                <p class="table-card-subtitle">Verification status, expiry timeline, and supporting compliance files.</p>
            </div>
        </div>
        <div class="report-center-actions">
            <a class="btn btn-outline-secondary btn-lg px-4" href="/Suppliers/Documents"><i class="fa-solid fa-folder-open"></i> View Documents</a>
        </div>
    </article>
</section>
