</div>
<section class="table-card erp-table-card">
    <div class="table-card-header">
        <div>
            <h3 class="table-card-title">Supplier Risk Watchlist</h3>
            <p class="table-card-subtitle">Operational watchlist of suppliers requiring immediate attention.</p>
