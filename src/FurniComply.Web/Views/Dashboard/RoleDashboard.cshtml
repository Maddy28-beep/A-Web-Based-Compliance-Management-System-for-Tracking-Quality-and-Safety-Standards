@model FurniComply.Web.Models.RoleDashboardViewModel
@using System.Globalization
@using System.Text.RegularExpressions

@{
    ViewData["Title"] = $"{Model.RoleName} Dashboard";
    var localNow = DateTime.Now;
    var isSuperAdminRole = string.Equals(Model.RoleName, "Super Admin", StringComparison.OrdinalIgnoreCase);
    var isProcurementRole = string.Equals(Model.RoleName, "Procurement Officer", StringComparison.OrdinalIgnoreCase);

    int ParseFirstInteger(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw))
        {
            return 0;
        }

        var match = Regex.Match(raw, @"-?\d+");
        return match.Success && int.TryParse(match.Value, NumberStyles.Integer, CultureInfo.InvariantCulture, out var value)
            ? value
            : 0;
    }

    int LookupNumber(params string[] keywords)
    {
        bool Match(string source) => keywords.Any(k => source.Contains(k, StringComparison.OrdinalIgnoreCase));

        foreach (var metric in Model.Metrics)
        {
            if (Match(metric.Title))
            {
                return ParseFirstInteger(metric.Value);
            }
        }

        foreach (var item in Model.ActionItems)
        {
            if (Match(item.Title))
            {
                return ParseFirstInteger(item.Detail);
            }
        }

        foreach (var item in Model.Alerts)
        {
            if (Match(item.Title))
            {
                return ParseFirstInteger(item.Detail);
            }
        }

        return 0;
    }

    var seedExpiringCerts = LookupNumber("expiring certs", "expiring");
    var seedOpenCapa = LookupNumber("open capa", "open capa / findings");
    var seedDraftOrders = LookupNumber("pending orders", "draft purchase orders");
    var seedApprovedOrders = LookupNumber("approved orders");
    var seedDocIssues = LookupNumber("supplier docs", "risk signals", "pending doc overrides", "document issues");
    var seedCompliantSuppliers = LookupNumber("suppliers compliant", "compliant suppliers");
    var seedSuspendedSuppliers = LookupNumber("suspended suppliers", "suppliers blocked", "non-compliant suppliers");
    var seedTotalSuppliers = LookupNumber("total suppliers");
    var seedActiveSuppliers = LookupNumber("active suppliers") > 0 ? LookupNumber("active suppliers") : (seedTotalSuppliers > 0 ? Math.Max(seedTotalSuppliers - seedSuspendedSuppliers, 0) : 0);
}

<div class="erp-cockpit">
<section class="dash-hero @(isSuperAdminRole ? "superadmin-hero" : "")">
    <div>
        <p class="eyebrow">ERP Operations</p>
        @if (isSuperAdminRole)
        {
            <span class="superadmin-mark">Governance Mode</span>
        }
        <h1>@Model.RoleName Dashboard</h1>
        <p class="lede">@Model.Focus</p>
        <div class="dash-meta">
            <span>Last refresh: <strong>@localNow.ToString("MMM dd, yyyy hh:mm tt")</strong></span>
            <span>Source: <strong>Live operational modules</strong></span>
        </div>
        <div class="dash-date-filter @(Context.Request.Query.ContainsKey("from") || Context.Request.Query.ContainsKey("to") ? "dash-date-filter-active" : "")">
            <div class="dash-date-filter-header">
                <span class="dash-date-filter-label"><i class="fa-solid fa-calendar-days"></i> Date range</span>
                @if (Context.Request.Query.ContainsKey("from") || Context.Request.Query.ContainsKey("to"))
                {
                    <span class="dash-date-filter-badge"><i class="fa-solid fa-check"></i> Filtered</span>
                }
            </div>
            <form class="dash-date-filter-form" method="get" asp-action="Index" asp-controller="Dashboard">
                <div class="dash-date-inputs">
                    <label class="dash-date-field">
                        <span class="dash-date-field-label">From</span>
                        <input type="date" name="from" id="dashFrom" class="form-control" value="@Context.Request.Query["from"]" />
                    </label>
                    <span class="dash-date-sep">—</span>
                    <label class="dash-date-field">
                        <span class="dash-date-field-label">To</span>
                        <input type="date" name="to" id="dashTo" class="form-control" value="@Context.Request.Query["to"]" />
                    </label>
                </div>
                <div class="dash-date-actions">
                    <button type="submit" class="btn btn-success dash-date-apply"><i class="fa-solid fa-filter"></i> Apply</button>
                    @if (Context.Request.Query.ContainsKey("from") || Context.Request.Query.ContainsKey("to"))
                    {
                        <a href="@Context.Request.Path" class="btn btn-outline-secondary dash-date-reset"><i class="fa-solid fa-rotate-left"></i> Reset</a>
                    }
                </div>
            </form>
        </div>
    </div>
    <div class="dash-actions role-dash-actions">
        <a class="button ghost" href="/AuditLogs/Index"><i class="fa-solid fa-fingerprint me-2"></i>Audit Logs</a>
        <a class="button ghost" href="/Suppliers/Index"><i class="fa-solid fa-industry me-2"></i>Suppliers</a>
        <a class="button ghost" href="/ProcurementOrders/Index"><i class="fa-solid fa-file-invoice-dollar me-2"></i>Orders</a>
        @if (!isSuperAdminRole && !isProcurementRole)
        {
            <a class="button ghost" href="/Capa/Index"><i class="fa-solid fa-toolbox me-2"></i>CAPA Dashboard</a>
        }
    </div>
</section>

<div class="erp-section-header">
    <span class="erp-section-badge"><i class="fa-solid fa-gauge-high"></i></span>
    <div>
        <h2 class="erp-section-title">System Status</h2>
        <p class="erp-section-desc">Quick overview of supplier operational status and procurement activity.</p>
        <p class="erp-section-meta small text-muted mb-0">Early-warning alerts track <strong>expiring certifications</strong> (within 30 days) and <strong>overdue renewals</strong>. View <a href="/Suppliers/Documents">Supplier Documents</a> for expiry dates.</p>
    </div>
</div>
<section class="erp-kpi-grid">
    <a class="erp-kpi-card @(seedExpiringCerts > 0 ? "kpi-soft-orange" : "kpi-soft-slate")" href="/Suppliers/Documents?expiring=1" title="Certifications expiring within 30 days or already overdue">
        <div class="erp-kpi-icon" aria-hidden="true"><i class="fa-solid fa-bell"></i></div>
        <div class="erp-kpi-value" id="kpiActiveAlerts">@seedExpiringCerts</div>
        <div class="erp-kpi-label">Expiring Certs &amp; Renewals</div>
    </a>
    <a class="erp-kpi-card kpi-soft-slate" href="/Suppliers/Index">
        <div class="erp-kpi-icon" aria-hidden="true"><i class="fa-solid fa-industry"></i></div>
        <div class="erp-kpi-value" id="kpiTotalSuppliers">@seedTotalSuppliers</div>
        <div class="erp-kpi-label">Total Suppliers</div>
    </a>
    <a class="erp-kpi-card kpi-soft-green" href="/Suppliers/Index">
        <div class="erp-kpi-icon" aria-hidden="true"><i class="fa-solid fa-user-check"></i></div>
        <div class="erp-kpi-value" id="kpiActiveSuppliers">@seedActiveSuppliers</div>
        <div class="erp-kpi-label">Active Suppliers</div>
    </a>
    <a class="erp-kpi-card kpi-soft-orange" href="/Suppliers/Index">
        <div class="erp-kpi-icon" aria-hidden="true"><i class="fa-solid fa-user-lock"></i></div>
        <div class="erp-kpi-value" id="kpiSuspendedSuppliers">@seedSuspendedSuppliers</div>
        <div class="erp-kpi-label">Suspended Suppliers</div>
    </a>
    <a class="erp-kpi-card kpi-soft-green" href="/Suppliers/Index">
        <div class="erp-kpi-icon" aria-hidden="true"><i class="fa-solid fa-circle-check"></i></div>
        <div class="erp-kpi-value" id="kpiSuppliersCompliant">@seedCompliantSuppliers</div>
        <div class="erp-kpi-label">Suppliers Compliant</div>
    </a>
    <a class="erp-kpi-card kpi-soft-red" href="/Suppliers/Documents">
        <div class="erp-kpi-icon" aria-hidden="true"><i class="fa-solid fa-folder-open"></i></div>
        <div class="erp-kpi-value" id="kpiSuppliersDocIssues">@seedDocIssues</div>
        <div class="erp-kpi-label">Suppliers With Document Issues</div>
    </a>
    <a class="erp-kpi-card kpi-soft-orange" href="/Capa/Index">
        <div class="erp-kpi-icon" aria-hidden="true"><i class="fa-solid fa-triangle-exclamation"></i></div>
        <div class="erp-kpi-value" id="kpiOpenCapa">@seedOpenCapa</div>
        <div class="erp-kpi-label">Open CAPA Cases</div>
    </a>
    <a class="erp-kpi-card kpi-soft-green" href="/ProcurementOrders/Index">
        <div class="erp-kpi-icon" aria-hidden="true"><i class="fa-solid fa-clipboard-check"></i></div>
        <div class="erp-kpi-value" id="kpiApprovedOrders">@seedApprovedOrders</div>
        <div class="erp-kpi-label">Approved Orders</div>
    </a>
</section>

<div class="erp-section-header">
    <span class="erp-section-badge"><i class="fa-solid fa-chart-line"></i></span>
    <div>
        <h2 class="erp-section-title">Compliance Analytics</h2>
        <p class="erp-section-desc">Risk patterns and supplier compliance performance monitoring.</p>
    </div>
</div>
<section class="erp-analytics-grid">
