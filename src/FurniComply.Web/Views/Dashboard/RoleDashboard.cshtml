        <canvas id="erpCapaActivityChart"></canvas>
        <div class="chart-metrics">
            <div><small><span class="metric-dot" style="background:#2b64c6;"></span>Open CAPA</small><strong id="capaOpenLabel">0</strong></div>
            <div><small><span class="metric-dot" style="background:#2b8a5a;"></span>Closed CAPA</small><strong id="capaClosedLabel">0</strong></div>
