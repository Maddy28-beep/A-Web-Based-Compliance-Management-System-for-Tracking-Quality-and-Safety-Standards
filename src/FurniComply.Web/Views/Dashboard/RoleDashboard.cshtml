            <span class="risk-metric"><span class="metric-dot" style="background:#2b8a5a;"></span>Peak <strong id="trendPeakLabel">0</strong></span>
            <span class="risk-metric"><span class="metric-dot" style="background:#607168;"></span>Period <strong id="trendPeriodLabel">0 months</strong></span>
