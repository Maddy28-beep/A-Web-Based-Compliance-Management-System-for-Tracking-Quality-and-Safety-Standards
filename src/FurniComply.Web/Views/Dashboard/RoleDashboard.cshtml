    </div>
    <div class="detail-table-wrap">
        <table class="table compact">
            <thead>
                <tr>
                    <th>Supplier</th>
                    <th class="table-cell-right">Compliance Score</th>
                    <th class="table-cell-center">Risk Level</th>
                </tr>
            </thead>
            <tbody id="erpRiskWatchlistBody">
                <tr>
                    <td colspan="3" class="text-center py-3">Loading data...</td>
                </tr>
            </tbody>
        </table>
    </div>
</section>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        (function () {
            const textOf = (el) => (el ? (el.textContent || "").trim() : "");
            const toInt = (value) => {
                const match = String(value ?? "").match(/-?\d+/);
                return match ? Number(match[0]) : 0;
            };

            const escapeHtml = (raw) => String(raw ?? "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll("\"", "&quot;")
                .replaceAll("'", "&#39;");

            const setValue = (id, value) => {
                const el = document.getElementById(id);
                if (el) el.textContent = String(value);
            };

            const setRows = (tbodyId, rows, emptyCols, emptyText) => {
                const body = document.getElementById(tbodyId);
                if (!body) return;
                if (!rows || rows.length === 0) {
                    body.innerHTML = `<tr><td colspan="${emptyCols}" class="text-center py-3">${escapeHtml(emptyText)}</td></tr>`;
                    return;
                }
                body.innerHTML = rows.join("");
            };

            const fetchHtml = async (path) => {
                try {
                    const response = await fetch(path, { credentials: "same-origin" });
                    if (!response.ok) return null;
                    const html = await response.text();
                    return new DOMParser().parseFromString(html, "text/html");
                } catch {
                    return null;
                }
            };

            const parseSupplierData = (doc) => {
                const rows = Array.from(doc?.querySelectorAll("table.suppliers-table tbody tr") ?? []);
                const suppliers = rows.map((row) => {
                    const name = textOf(row.querySelector("td:nth-child(2)"));
                    const status = textOf(row.querySelector("td:nth-child(4) .badge"));
                    const approval = textOf(row.querySelector("td:nth-child(5) .approval-pill"));
                    const ratingText = textOf(row.querySelector(".supplier-rating-value"));
                    const riskBand = textOf(row.querySelector(".supplier-rating-band"));
                    const rating = Number.parseFloat(ratingText || "0");
                    const score = Number.isFinite(rating) ? Math.round(rating * 20) : 0;

                    const hasDocIssue = status.includes("SUSPENDED") || status.includes("ON HOLD") || approval.includes("PENDING") || approval.includes("REJECTED");
                    const highRisk = riskBand.toUpperCase().includes("NEEDS ATTENTION") || riskBand.toUpperCase().includes("HIGH") || status.includes("SUSPENDED");
                    const atRisk = !highRisk && (riskBand.toUpperCase().includes("ADEQUATE") || riskBand.toUpperCase().includes("MEDIUM") || status.includes("ON HOLD"));
                    const compliant = status.includes("ACTIVE") && approval.includes("APPROVED") && riskBand.toUpperCase().includes("LOW");

                    return { name, status, approval, riskBand, score, hasDocIssue, highRisk, atRisk, compliant };
                });

                const total = suppliers.length;
                const active = suppliers.filter(s => s.status.includes("ACTIVE")).length;
                const suspended = suppliers.filter(s => s.status.includes("SUSPENDED")).length;
                const compliantCount = suppliers.filter(s => s.compliant).length;
                const docIssues = suppliers.filter(s => s.hasDocIssue).length;
                const highRisk = suppliers.filter(s => s.highRisk).length;
                const atRisk = suppliers.filter(s => s.atRisk).length;

                const watchlist = suppliers
                    .filter(s => s.highRisk || s.atRisk || s.hasDocIssue)
                    .sort((a, b) => a.score - b.score)
                    .slice(0, 8)
                    .map(s => {
                        const riskLevel = s.highRisk ? "Needs Attention" : "Adequate";
                        const chipClass = s.highRisk ? "status-chip risk" : "status-chip warn";
                        return `<tr>
                            <td>${escapeHtml(s.name || "-")}</td>
                            <td class="table-cell-right">${escapeHtml(s.score)}</td>
                            <td class="table-cell-center"><span class="${chipClass}">${escapeHtml(riskLevel)}</span></td>
                        </tr>`;
                    });

                return { total, active, suspended, compliantCount, docIssues, highRisk, atRisk, watchlist };
            };

            const parseOrdersData = (doc) => {
                const rows = Array.from(doc?.querySelectorAll("table.order-queue-table tbody tr") ?? []);
                let draft = 0;
                let approved = 0;

                const recentRows = rows.slice(0, 6).map((row) => {
                    const cells = row.querySelectorAll("td");
                    const order = textOf(cells[0]);
                    const amount = textOf(cells[1]);
                    const supplier = textOf(cells[2]);
                    const status = textOf(cells[3]);

                    const upperStatus = status.toUpperCase();
                    if (upperStatus.includes("DRAFT")) draft++;
                    if (upperStatus.includes("APPROVED") || upperStatus.includes("ORDERED") || upperStatus.includes("RECEIVED")) approved++;

                    const chip = upperStatus.includes("APPROVED") || upperStatus.includes("ORDERED") || upperStatus.includes("RECEIVED")
                        ? "status-chip good"
                        : upperStatus.includes("DRAFT") || upperStatus.includes("SUBMITTED")
                            ? "status-chip neutral"
                            : upperStatus.includes("REJECTED") || upperStatus.includes("CANCELLED")
                                ? "status-chip risk"
                                : "status-chip muted";

                    return `<tr>
                        <td>${escapeHtml(order || "-")}</td>
                        <td>${escapeHtml(supplier || "-")}</td>
                        <td class="table-cell-center"><span class="${chip}">${escapeHtml(status || "-")}</span></td>
                        <td class="table-cell-right amount-cell"><span class="amount-nowrap">${escapeHtml(amount || "-")}</span></td>
                    </tr>`;
                });

                if (rows.length > recentRows.length) {
                    const allStatuses = rows.map((row) => textOf(row.querySelector("td:nth-child(3)")).toUpperCase());
                    draft = allStatuses.filter(s => s.includes("DRAFT")).length;
                    approved = allStatuses.filter(s => s.includes("APPROVED") || s.includes("ORDERED") || s.includes("RECEIVED")).length;
                }

                return { draft, approved, recentRows };
            };

            const parseCapaData = (doc) => {
                const rows = Array.from(doc?.querySelectorAll("table.capa-table tbody tr") ?? []);
                let open = 0;
                let closed = 0;
                let overdue = 0;

                const monitoringRows = rows.slice(0, 8).map((row) => {
                    const issue = textOf(row.querySelector("td:nth-child(1) .badge")) || textOf(row.querySelector("td:nth-child(1)"));
                    const supplier = textOf(row.querySelector("td:nth-child(2)"));
                    const capaStatus = textOf(row.querySelector("td:nth-child(4) .badge")) || textOf(row.querySelector("td:nth-child(4)"));
                    const upper = capaStatus.toUpperCase();

                    if (upper.includes("OVERDUE")) overdue++;
                    else if (upper.includes("CLOSED")) closed++;
                    else open++;

                    const chipClass = upper.includes("OVERDUE")
                        ? "status-chip risk"
                        : upper.includes("CLOSED")
                            ? "status-chip good"
                            : "status-chip neutral";

                    return `<tr>
                        <td>${escapeHtml(supplier || "-")}</td>
                        <td>${escapeHtml(issue || "-")}</td>
                        <td class="table-cell-center"><span class="${chipClass}">${escapeHtml(capaStatus || "-")}</span></td>
                    </tr>`;
                });

                if (rows.length > monitoringRows.length) {
                    const allStatuses = rows.map((row) => (textOf(row.querySelector("td:nth-child(4)")).toUpperCase()));
                    overdue = allStatuses.filter(s => s.includes("OVERDUE")).length;
                    closed = allStatuses.filter(s => s.includes("CLOSED")).length;
                    open = Math.max(allStatuses.length - overdue - closed, 0);
                }

                return { open, closed, overdue, monitoringRows };
            };

            const buildCharts = (trendLabels, trendValues, riskData, capaData) => {
                if (!window.Chart) return;

                const trendCtx = document.getElementById("erpComplianceTrendChart");
                const riskCtx = document.getElementById("erpRiskDistributionChart");
                const capaCtx = document.getElementById("erpCapaActivityChart");

                if (trendCtx) {
                    const gradient = trendCtx.getContext("2d").createLinearGradient(0, 0, 0, 300);
                    gradient.addColorStop(0, "rgba(31, 90, 69, 0.25)");
                    gradient.addColorStop(1, "rgba(31, 90, 69, 0.02)");
                    new Chart(trendCtx, {
                        type: "line",
                        data: {
                            labels: trendLabels,
                            datasets: [{
                                label: "Checks",
                                data: trendValues,
                                borderColor: "#1f5a45",
                                backgroundColor: gradient,
                                fill: true,
                                tension: 0.4,
                                borderWidth: 2.5,
                                pointBackgroundColor: "#ffffff",
                                pointBorderColor: "#1f5a45",
                                pointBorderWidth: 2,
                                pointRadius: 4,
                                pointHoverRadius: 7,
                                pointHoverBackgroundColor: "#1f5a45",
                                pointHoverBorderColor: "#ffffff",
                                pointHoverBorderWidth: 2
                            }]
                        },
                        options: {
                            plugins: { legend: { display: false } },
                            animation: { duration: 800 },
                            scales: {
                                y: {
                                    beginAtZero: true,
                                    ticks: { precision: 0, stepSize: 1 },
                                    grid: { color: "rgba(31, 54, 44, 0.06)" }
                                },
                                x: {
                                    grid: { display: false }
                                }
                            },
                            responsive: true,
                            maintainAspectRatio: false
                        }
                    });
                    const vals = (trendValues || []).map(v => Number(v) || 0);
                    const latest = vals.length > 0 ? vals[vals.length - 1] : 0;
                    const latestLabel = trendLabels && trendLabels.length > 0 ? trendLabels[trendLabels.length - 1] : "-";
                    const peak = vals.length > 0 ? Math.max(...vals) : 0;
                    const period = trendLabels ? trendLabels.length : 0;
                    setValue("trendLatestLabel", latest);
                    setValue("trendPeakLabel", peak);
                    setValue("trendPeriodLabel", period > 0 ? period + " months" : "-");
                }

                if (riskCtx) {
                    const rawRiskValues = [riskData.compliant, riskData.atRisk, riskData.highRisk].map(v => Number(v) || 0);
                    const rawRiskTotal = rawRiskValues.reduce((sum, current) => sum + current, 0);
                    const epsilon = 0.001;
                    const displayRiskValues = rawRiskValues.map(v => (v === 0 ? epsilon : v));

                    const compliantPct = rawRiskTotal > 0 ? ((rawRiskValues[0] / rawRiskTotal) * 100).toFixed(1) : "0.0";
                    const atRiskPct = rawRiskTotal > 0 ? ((rawRiskValues[1] / rawRiskTotal) * 100).toFixed(1) : "0.0";
                    const highRiskPct = rawRiskTotal > 0 ? ((rawRiskValues[2] / rawRiskTotal) * 100).toFixed(1) : "0.0";

                    setValue("riskCompliantLabel", `${rawRiskValues[0]} (${compliantPct}%)`);
                    setValue("riskAtRiskLabel", `${rawRiskValues[1]} (${atRiskPct}%)`);
                    setValue("riskHighRiskLabel", `${rawRiskValues[2]} (${highRiskPct}%)`);

                    new Chart(riskCtx, {
                        type: "doughnut",
                        data: {
                            labels: ["Compliant", "Adequate", "Needs Attention"],
                            datasets: [{
                                data: displayRiskValues,
                                backgroundColor: ["#2b8a5a", "#2b64c6", "#c03b47"],
                                borderWidth: 2,
                                borderColor: "#ffffff",
                                hoverBorderColor: "#ffffff",
                                hoverOffset: 6
                            }]
                        },
                        options: {
                            plugins: {
                                legend: { display: false },
                                tooltip: {
                                    callbacks: {
                                        label: function (context) {
                                            const index = context.dataIndex;
                                            const labels = ["Compliant", "Adequate", "Needs Attention"];
                                            const pct = index === 0 ? compliantPct : (index === 1 ? atRiskPct : highRiskPct);
                                            return `${labels[index]}: ${rawRiskValues[index]} (${pct}%)`;
                                        }
                                    }
                                }
                            },
                            cutout: "66%",
                            responsive: true,
                            maintainAspectRatio: false
                        }
                    });
                }

                if (capaCtx) {
                    const rawCapaValues = [capaData.open, capaData.closed, capaData.overdue].map(v => Number(v) || 0);
                    const displayCapaValues = rawCapaValues.map(v => (v === 0 ? 0.03 : v));

                    setValue("capaOpenLabel", rawCapaValues[0]);
                    setValue("capaClosedLabel", rawCapaValues[1]);
                    setValue("capaOverdueLabel", rawCapaValues[2]);

                    new Chart(capaCtx, {
                        type: "bar",
                        data: {
                            labels: ["Open CAPA", "Closed CAPA", "Overdue CAPA"],
                            datasets: [{
                                data: displayCapaValues,
                                backgroundColor: ["#2b64c6", "#2b8a5a", "#c03b47"],
                                borderRadius: 6,
                                maxBarThickness: 48
                            }]
                        },
                        options: {
                            plugins: { legend: { display: false } },
                            scales: {
                                y: {
                                    beginAtZero: true,
                                    suggestedMax: Math.max(5, rawCapaValues[0], rawCapaValues[1], rawCapaValues[2]),
                                    ticks: { precision: 0, stepSize: 1 },
                                    grid: { color: "rgba(31, 54, 44, 0.06)" }
                                },
                                x: {
                                    grid: { display: false }
                                }
                            },
                            responsive: true,
                            maintainAspectRatio: false
                        }
                    });
                }
            };

            var hasDateFilter = @(string.IsNullOrEmpty(ViewBag.DateFilterFrom as string) && string.IsNullOrEmpty(ViewBag.DateFilterTo as string) ? "false" : "true");
            var filterFrom = "@(ViewBag.DateFilterFrom ?? "")";
            var filterTo = "@(ViewBag.DateFilterTo ?? "")";
            var trendUrl = hasDateFilter && (filterFrom || filterTo)
                ? "/Dashboard/TrendData?metric=checks&from=" + encodeURIComponent(filterFrom) + "&to=" + encodeURIComponent(filterTo)
                : "/Dashboard/TrendData?metric=checks";

            Promise.all([
                hasDateFilter ? Promise.resolve(null) : fetchHtml("/Suppliers/Index"),
                hasDateFilter ? Promise.resolve(null) : fetchHtml("/ProcurementOrders/Index"),
                hasDateFilter ? Promise.resolve(null) : fetchHtml("/Capa/Index"),
                fetch(trendUrl, { credentials: "same-origin" }).then(r => r.ok ? r.json() : null).catch(() => null)
            ]).then(([suppliersDoc, ordersDoc, capaDoc, trendData]) => {
                var supplierData = hasDateFilter ? {} : parseSupplierData(suppliersDoc || "");
                var ordersData = hasDateFilter ? {} : parseOrdersData(ordersDoc || "");
                var capaData = hasDateFilter ? {} : parseCapaData(capaDoc || "");

                if (!hasDateFilter) {
                    setValue("kpiTotalSuppliers", supplierData.total || @seedTotalSuppliers);
                    setValue("kpiActiveSuppliers", supplierData.active || @seedActiveSuppliers);
                    setValue("kpiSuspendedSuppliers", supplierData.suspended || @seedSuspendedSuppliers);
                    setValue("kpiSuppliersCompliant", supplierData.compliantCount || @seedCompliantSuppliers);
                    setValue("kpiSuppliersDocIssues", supplierData.docIssues || @seedDocIssues);
                    setValue("kpiOpenCapa", capaData.open || @seedOpenCapa);
                    setValue("kpiDraftOrders", ordersData.draft || @seedDraftOrders);
                    setValue("kpiApprovedOrders", ordersData.approved || @seedApprovedOrders);
                    setRows("erpRecentOrdersBody", ordersData.recentRows || [], 4, "No purchase orders available.");
                    setRows("erpCapaMonitoringBody", capaData.monitoringRows || [], 3, "No CAPA records available.");
                    setRows("erpRiskWatchlistBody", supplierData.watchlist || [], 3, "No watchlist items.");
                }

                const labels = Array.isArray(trendData?.labels) ? trendData.labels : [];
                const values = Array.isArray(trendData?.values) ? trendData.values.map(v => Number(v) || 0) : [];

                buildCharts(
                    labels.length ? labels : ["No Data"],
                    values.length ? values : [0],
                    {
                        compliant: hasDateFilter ? @seedCompliantSuppliers : (supplierData.compliantCount || @seedCompliantSuppliers),
                        atRisk: supplierData.atRisk || 0,
                        highRisk: hasDateFilter ? @seedSuspendedSuppliers : (supplierData.highRisk || @seedSuspendedSuppliers)
                    },
                    {
                        open: hasDateFilter ? @seedOpenCapa : (capaData.open || @seedOpenCapa),
                        closed: capaData.closed || 0,
                        overdue: capaData.overdue || 0
                    }
                );
            }).catch(() => {
                setRows("erpRecentOrdersBody", [], 4, "Unable to load order data.");
                setRows("erpCapaMonitoringBody", [], 3, "Unable to load CAPA data.");
                setRows("erpRiskWatchlistBody", [], 3, "Unable to load risk watchlist.");
                buildCharts(
                    ["No Data"],
                    [0],
                    { compliant: 0, atRisk: 0, highRisk: 0 },
                    { open: 0, closed: 0, overdue: 0 }
                );
            });
        })();
    </script>
}
