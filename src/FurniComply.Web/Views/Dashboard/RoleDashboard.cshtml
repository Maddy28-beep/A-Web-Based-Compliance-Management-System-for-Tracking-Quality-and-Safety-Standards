        </div>
        <canvas id="erpRiskDistributionChart"></canvas>
        <div class="chart-metrics chart-metrics-inline">
            <span class="risk-metric"><span class="metric-dot" style="background:#2b8a5a;"></span>Compliant <strong id="riskCompliantLabel">0 (0%)</strong></span>
            <span class="risk-metric"><span class="metric-dot" style="background:#2b64c6;"></span>Adequate <strong id="riskAtRiskLabel">0 (0%)</strong></span>
            <span class="risk-metric"><span class="metric-dot" style="background:#c03b47;"></span>Needs Attention <strong id="riskHighRiskLabel">0 (0%)</strong></span>
        </div>
    </div>
    <div class="chart-card">
        <div class="chart-header">
